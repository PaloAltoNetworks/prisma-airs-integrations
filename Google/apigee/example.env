# Apigee Configuration
APIGEE_ORG="your-apigee-org"
APIGEE_ENV="eval"  # or test, prod

# Prisma AIRS Configuration
PRISMA_AIRS_API_KEY="your-airs-api-key-here"
PRISMA_AIRS_PROFILE_NAME="your-profile-name"
# Region-bound AIRS API host — match the tenant that issued your key
# (US default shown; EU=service-de..., IN=service-in..., SG=service-sg...)
PRISMA_AIRS_HOST="service.api.aisecurity.paloaltonetworks.com"

# GCP/Vertex AI Configuration
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
VERTEX_MODEL="enabled model in VertexAI model garden"

# Deployment service account EMAIL (not a key file). deploy.sh deploys via
# the Apigee mgmt API's serviceAccount= param using your own gcloud login —
# your user just needs iam.serviceAccounts.actAs on this SA.
DEPLOY_SA="apigee-vertex-sa@your-gcp-project-id.iam.gserviceaccount.com"

# Optional: env-group hostname, used only to print a ready-to-paste smoke
# test curl at the end of deploy.sh. Omit if you don't want it.
# HOSTNAME=apicc-dev.gcl.corp.intranet

# Optional: Skip IAM grant during deployment (set to 1 to skip)
# SKIP_IAM_GRANT=1
