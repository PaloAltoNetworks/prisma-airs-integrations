# Azure APIM Configuration
AZURE_SUB_ID=<AZURE_SUBSCRIPTION_ID>
AZURE_RG=<AZURE_RESOURCE_GROUP>
AZURE_SERVICE=<AZURE_APIM_SERVICE_NAME>

# API Authentication (used by all test scripts)
# AZURE_APIM_KEY: The API key or subscription key value
# AZURE_APIM_HEADER: The header name to use (defaults to "Ocp-Apim-Subscription-Key")
#
# Examples:
#   For APIM subscription key: AZURE_APIM_HEADER="Ocp-Apim-Subscription-Key"
#   For OpenAI/Foundry api-key: AZURE_APIM_HEADER="api-key"
#
AZURE_APIM_KEY=<YOUR_API_KEY>
# AZURE_APIM_HEADER="api-key"  # Uncomment and set for non-APIM headers

# =============================================================================
# API Endpoint Configuration (v3 Unified Fragment supports all these)
# =============================================================================

# MCP Server API
# Auto-built URL: https://{AZURE_SERVICE}.azure-api.net/{MCP_API_NAME}/mcp
MCP_API_NAME=<MCP_API_NAME>
# Optional: Override with custom URL
# MCP_SERVER_URL="https://{custom-domain}/path/mcp"

# OpenAI API
# Auto-built URL: https://{AZURE_SERVICE}.azure-api.net/{OPENAI_API_NAME}/chat/completions
OPENAI_API_NAME=<OPENAI_API_NAME>
# Optional: Override with custom URL
# OPENAI_SERVER_URL="https://mgollop-aigw-svs.azure-api.net/my-llm/chat/completions"


# Azure AI Foundry Claude API (Anthropic-style /v1/messages)
# Auto-built URL: https://{AZURE_SERVICE}.azure-api.net/{FOUNDRY_CLAUDE_API_NAME}/v1/messages
FOUNDRY_CLAUDE_API_NAME=<FOUNDRY_CLAUDE_API_NAME>
# Optional: Override with custom URL
# FOUNDRY_CLAUDE_SERVER_URL="https://mgollop-aigw-svs.azure-api.net/foundry-claude/v1/messages"

# Azure AI Foundry GPT API (OpenAI Responses API /openai/v1/responses)
# Auto-built URL: https://{AZURE_SERVICE}.azure-api.net/{FOUNDRY_GPT_API_NAME}/openai/v1/responses
FOUNDRY_GPT_API_NAME=<FOUNDRY_GPT_API_NAME>
# Optional: Override with custom URL
# FOUNDRY_GPT_SERVER_URL="https://mgollop-aigw-svs.azure-api.net/foundry-gpt/openai/v1/responses"


# Anthropic API
# Auto-built URL: https://{AZURE_SERVICE}.azure-api.net/{ANTHROPIC_API_NAME}/v1/messages
ANTHROPIC_API_NAME=<ANTHROPIC_API_NAME>
# Optional: Override with custom URL
# ANTHROPIC_SERVER_URL="https://{custom-domain}/v1/messages"

# Gemini API
# Auto-built URL: https://{AZURE_SERVICE}.azure-api.net/{GEMINI_API_NAME}/v1beta/models/{GEMINI_MODEL}:generateContent
GEMINI_API_NAME=<GEMINI_API_NAME>
# Optional: Override with custom URL
# GEMINI_SERVER_URL="https://{custom-domain}/v1beta/models/gemini-2.5-flash:generateContent"

# =============================================================================
# Test Configuration
# =============================================================================

# Trace Configuration (will be auto-generated if not set)
AZURE_TRACE_ID="test-trace-$(date +%s)"

# Token cache files (auto-managed by scripts)
AZURE_API_TOKEN_FILE=.azure_api_token
AZURE_DEBUG_TOKEN_FILE=.azure_debug_token

# Test Model Configuration
OPENAI_MODEL="gpt-4"
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"
FOUNDRY_CLAUDE_MODEL="claude-haiku-4-5"
FOUNDRY_GPT_MODEL="gpt-5.4-nano"
GEMINI_MODEL="gemini-2.5-flash"
