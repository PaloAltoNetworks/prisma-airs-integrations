# Prisma AIRS Configuration for Cursor Security Hooks
# Copy this file to .env and configure your settings

# ============================================
# REQUIRED: Prisma AIRS API Configuration
# ============================================

# Your Prisma AIRS API token
# Get this from: https://www.paloaltonetworks.com/prisma/ai-runtime-security
PRISMA_AIRS_API_KEY="your-prisma-airs-api-key-here"

# ============================================
# OPTIONAL: API Endpoint
# ============================================

# Prisma AIRS API base URL
# Default endpoint is used when this is unset
# PRISMA_AIRS_API_URL="https://service.api.aisecurity.paloaltonetworks.com/v1/scan/sync/request"

# ============================================
# OPTIONAL: Security Profile Configuration
# ============================================

# Security profile name (configure in Prisma AIRS)
PRISMA_AIRS_PROFILE_NAME="your-security-profile-name"

# ============================================
# USAGE INSTRUCTIONS
# ============================================

# 1. Copy this file to .env:
#    cp example.env .env

# 2. Edit .env and add your PRISMA_AIRS_API_KEY

# 3. Source the environment file before using Cursor:
#    source .env

# 4. Or export variables in your shell profile (~/.zshrc or ~/.bashrc):
#    echo 'export PRISMA_AIRS_API_KEY="your-key-here"' >> ~/.zshrc
#    echo 'export PRISMA_AIRS_PROFILE_NAME="your-security-profile-name"' >> ~/.zshrc

# Security logs are written to .cursor/hooks/prisma-airs.log inside the project root.

# ============================================
# SECURITY NOTES
# ============================================

# - NEVER commit .env file to version control
# - Add .env to your .gitignore
# - Rotate API keys every 90 days
# - Use restrictive profiles in production
# - Monitor prisma-airs.log for false positives
